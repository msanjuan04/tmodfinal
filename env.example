# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (para operaciones del servidor)
# IMPORTANTE: Esta clave debe mantenerse secreta y solo usarse en el servidor
# Obtén tu service role key desde: https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Configuración del proyecto por defecto
SUPABASE_DEFAULT_PROJECT_SLUG=your-project-slug

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Clave secreta para sesiones (genera una con: openssl rand -hex 32)
SESSION_SECRET=your_secure_session_secret_here

# Configuración de cookies de sesión (opcional)
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_DOMAIN=.tudominio.com

# Configuración adicional
NODE_ENV=development

# Resend (Email) — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=hola@tudominio.com
# Opcionales
RESEND_BCC=
RESEND_AUDIENCE_ID=
RESEND_DRY_RUN=true
